@baseUrl = http://localhost:5048

### 1. 新增會員
# @name createMember
# @description CRUD 基礎測試：建立一名會員，後續測試以 memberId 取得、更新、刪除
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: crud-create-{{$randomInt 100000 999999}}

{
  "name": "John Doe",
  "email": "john-{{$randomInt 100000 999999}}@example.com"
}

{{
  exports.memberId = response.parsedBody.id;
}}

### 2. 取得所有會員
GET {{baseUrl}}/api/members
Accept: application/json

### 3. 取得單一會員
GET {{baseUrl}}/api/members/{{memberId}}
Accept: application/json

### 4. 更新會員
PUT {{baseUrl}}/api/members/{{memberId}}
Content-Type: application/json

{
  "name": "Jane Doe",
  "email": "jane@example.com"
}

### 5. 刪除會員
DELETE {{baseUrl}}/api/members/{{memberId}}

### 6. 確認刪除後回傳 404
GET {{baseUrl}}/api/members/{{memberId}}
Accept: application/json

# ──────────────────────────────────────────────────────────────────────────────
# 冪等鍵（Idempotency Key）測試
# ──────────────────────────────────────────────────────────────────────────────

### 冪等鍵測試準備：產生本次執行唯一的 key 與 email（避免重複執行時 DuplicateEmail）
{{
  exports.idemKey = `idem-key-${Date.now()}`;
  exports.idemEmail = `idem-alice-${Date.now()}@test.com`;
}}

### 7. 冪等鍵 - 首次請求（應 201）
# @name idempotentCreate
# @description 首次使用某 idempotency-key 建立會員，預期 201
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: {{idemKey}}

{
  "name": "Idempotent Alice",
  "email": "{{idemEmail}}"
}

### 8. 冪等鍵 - 重播相同請求（應 201 + X-Idempotent-Replay: true）
# @description 用同一個 key + 同一個 payload 再送一次，預期回傳快取的 201 並帶 X-Idempotent-Replay: true header
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: {{idemKey}}

{
  "name": "Idempotent Alice",
  "email": "{{idemEmail}}"
}

### 9. 冪等鍵 - 缺少 header（應 400）
# @description 未帶 Idempotency-Key header，預期 400
# @no-reject-unauthorized
POST {{baseUrl}}/api/members
Content-Type: application/json

{
  "name": "No Key Bob",
  "email": "no-key-bob-{{$randomInt 100000 999999}}@example.com"
}

### 10. 冪等鍵 - Fingerprint mismatch（應 422）
# @description 用同一個 key 但換不同的 payload，預期 422（已使用此 key 但 payload 不符）
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: {{idemKey}}

{
  "name": "Different Payload Carol",
  "email": "carol-different-{{$randomInt 100000 999999}}@example.com"
}

# ──────────────────────────────────────────────────────────────────────────────
# Failed 狀態重播測試
# 場景：第一次請求因業務錯誤失敗（409 DuplicateEmail），
#       之後用同 key + 同 payload 再打，應直接重播 409，不重新執行業務邏輯
# ──────────────────────────────────────────────────────────────────────────────

### 冪等鍵 Failed 重播測試準備
{{
  exports.failedKey = `idem-failed-${Date.now()}`;
  exports.duplicateEmail = `dup-${Date.now()}@test.com`;
}}

### 11. 先建立一位會員（佔用 email）
# @description 建立一位會員，其 email 將在下一步被重複使用以觸發 409
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: idem-pre-{{$randomInt 100000 999999}}

{
  "name": "Pre-existing Member",
  "email": "{{duplicateEmail}}"
}

### 12. 冪等鍵 - 業務失敗首次請求（應 409 DuplicateEmail）
# @description 用不同的 idempotency-key 嘗試建立相同 email 的會員，預期 409
#              此次請求會被記錄為 Failed 狀態
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: {{failedKey}}

{
  "name": "Duplicate Member",
  "email": "{{duplicateEmail}}"
}

### 13. 冪等鍵 - Failed 狀態重播（應 409 + X-Idempotent-Replay: true）
# @description 用同一個 key + 同一個 payload 再打一次，
#              預期直接重播快取的 409，不重新執行業務邏輯
POST {{baseUrl}}/api/members
Content-Type: application/json
Idempotency-Key: {{failedKey}}

{
  "name": "Duplicate Member",
  "email": "{{duplicateEmail}}"
}
